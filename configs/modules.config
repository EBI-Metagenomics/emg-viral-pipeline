                failOnError: false,
                pattern: "*.meta",
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ],
            [
                path: { "${params.output}/${meta.id}/${params.finaldir}/blast" },
                mode: params.publish_dir_mode,
                failOnError: false,
                pattern: "*.meta",
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
