    withName: VIRSORTER {
        publishDir = [
            [
                path: { "${params.output}/${meta.id}/${params.virusdir}" },
                enabled: params.publish_all,
                mode: params.publish_dir_mode,
                failOnError: false,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        ]
    }

    withName: VIRSORTER2 {
        // VirSorter2 results are published when concatenating the chunks
        ext.args = { "--use-conda-off" }
    }

    withName: TABIX_BGZIP {
        // The input name needs to be kept, it contains the meta.id already
        ext.prefix = { input.baseName }
        ext.args = { "--index" }
        publishDir = [
            path: { "${params.output}/${meta.id}/${params.finaldir}/gff" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            // The GFF may not be generated... (I'm carrying this over as it was done like that in the past.. we need to review)
            failOnError: false,
        ]
    }

    withName: TABIX_BGZIPTABIX {
        // The input name needs to be kept, it contains the meta.id already
        ext.prefix = { input.baseName }
        ext.args2 = { "--csi" }
        publishDir = [
            path: { "${params.output}/${meta.id}/${params.finaldir}/gff" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            // Tthe GFF may not be generated... (I'm carrying this over as it was done like that in the past.. we need to review)
            failOnError: false,
        ]
