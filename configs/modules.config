                mode: params.publish_dir_mode,
                failOnError: false,
                pattern: "*_modified.tsv",
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        ]
    }

    withName: HMMER {
        publishDir = [
            [
                path: { "${params.output}/${meta.id}/${params.hmmerdir}/${db.baseName}" },
                enabled: params.publish_all,
                mode: params.publish_dir_mode,
                failOnError: false,
                pattern: "*_hmm*.tbl",
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ],
            [
                path: { "${params.output}/${meta.id}/${params.hmmerdir}/${db.baseName}" },
